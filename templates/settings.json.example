{
  "_comment": "Place ce fichier dans .claude/settings.json (racine du projet). Doc: setup-kit/04-claude-code.md section d & e.",

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./app/**)",
      "Edit(./supabase/**)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(vercel *)",
      "Bash(supabase *)",
      "Bash(stripe *)"
    ],

    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env*.local)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
  },

  "includeCoAuthoredBy": true
}
