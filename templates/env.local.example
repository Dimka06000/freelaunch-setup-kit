# ─────────────────────────────────────────────────────────────
# .env.local — copie ce fichier en `.env.local` à la racine et remplis.
# ⚠️ NE JAMAIS COMMIT. (.env.local est gitignored par Next.js)
# Procédure de récupération de chaque clé → setup-kit/03-api-keys.md
# ─────────────────────────────────────────────────────────────

# ── Anthropic (features IA de l'app via @anthropic-ai/sdk) ──
ANTHROPIC_API_KEY=

# ── Supabase (base de données + auth) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
# Personal Access Token (CLI + MCP Supabase). Révoque sur dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ── Stripe (paiements) ── (test : pk_test_… / sk_test_…)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Donné par `stripe listen` en local :
STRIPE_WEBHOOK_SECRET=

# ── Resend (emails transactionnels) ──
RESEND_API_KEY=

# ── Google Cloud (OAuth login + Maps) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# ── GitHub OAuth (login "Se connecter avec GitHub") ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Secrets générés par toi (openssl rand -hex 32) ──
CRON_SECRET=
CALENDAR_TOKEN_ENCRYPTION_KEY=

# ── Vercel (injecté par `vercel env pull`, ne pas remplir à la main) ──
VERCEL_OIDC_TOKEN=

# ─────────────────────────────────────────────────────────────
# 🟦 OPTIONNEL — IA générative & data (selon ton produit)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
RUNWAY_API_KEY=
LUMALABS_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
TWITTER_BEARER_TOKEN=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
